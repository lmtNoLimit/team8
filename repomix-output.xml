// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Session {
  mongodb_id  String    @id @default(auto()) @map("_id") @db.ObjectId
  id          String    @unique
  shop        String
  state       String
  isOnline    Boolean   @default(false)
  scope       String?
  expires     DateTime?
  accessToken String
  userId      BigInt?
  firstName   String?
  lastName    String?
  email       String?
  accountOwner  Boolean  @default(false)
  locale        String?
  collaborator  Boolean? @default(false)
  emailVerified Boolean? @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model AgentFinding {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId

  agentId          String
  shop             String

  type             String   // "done", "action_needed", "insight"
  priority         Int      // 1-5 (1 = most critical)

  title            String
  description      String
  action           String?

  metadata         Json?

  status           String   @default("pending") // "pending", "applied", "dismissed"

  deduplicationKey String?
  externalId       String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([shop, agentId, deduplicationKey])
  @@index([shop, agentId])
  @@index([shop, type, status])
  @@index([createdAt])
}

model Review {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  shop         String
  productId    String
  productTitle String
  source       String   @default("seed") // "seed" | "judgeme" | "yotpo"
  author       String?
  rating       Int      // 1-5
  title        String?
  body         String
  verified     Boolean  @default(false)
  reviewDate   DateTime
  language     String?  @default("en")
  createdAt    DateTime @default(now())

  @@index([shop, productId])
  @@index([shop, rating])
}

model AgentSetting {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  shop       String
  agentId    String
  trustLevel String   @default("advisor") // "advisor" | "assistant" | "autopilot"
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([shop, agentId])
}

model StoreProfile {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  shop             String   @unique
  storeName        String?
  industry         String?
  targetAudience   String?
  storeDescription String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  shop      String
  type      String   // "agent_run" | "finding_applied" | "finding_dismissed" | "agent_auto_executed"
  agentId   String?
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([shop, createdAt])
  @@index([shop, agentId])
}

model ShopPlan {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  shop                  String    @unique
  tier                  String    @default("free") // "free" | "starter" | "pro" | "agency"
  shopifySubscriptionId String?
  subscriptionStatus    String    @default("active") // "active" | "pending" | "frozen" | "cancelled"
  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model ProductCount {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  shop     String   @unique
  count    Int      @default(0)
  syncedAt DateTime @default(now())
}

model RunFrequencyLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  shop      String
  weekStart DateTime
  runCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, weekStart])
  @@index([shop])
}

model StoreAssignment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  primaryShop String
  managedShop String
  addedAt     DateTime @default(now())

  @@unique([primaryShop, managedShop])
  @@index([primaryShop])
}
</file>

