# MongoDB Atlas connection string
# Get yours at: https://cloud.mongodb.com/
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"

# Shopify app credentials (auto-injected by Shopify CLI during `npm run dev`)
# Only set manually if running outside of Shopify CLI
# SHOPIFY_API_KEY=""
# SHOPIFY_API_SECRET=""

# App scopes
SCOPES="write_products"

# App URL (auto-set by Shopify CLI tunnel)
# SHOPIFY_APP_URL=""

# Optional: custom shop domain
# SHOP_CUSTOM_DOMAIN=""
